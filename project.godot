; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="BaguetteFrench"
run/main_scene="uid://c4dngglnu3nqf"
config/quit_on_go_back=false
config/features=PackedStringArray("4.5", "Mobile")
boot_splash/bg_color=Color(0.12941177, 0.20392157, 0.17254902, 1)
boot_splash/fullsize=false
boot_splash/image="uid://0yneq6ildywm"
config/icon="uid://ixx22bl3ch4u"

[audio]

general/text_to_speech=true

[autoload]

SpeakHandler="*res://scripts/autoloads/SpeakHandler.gd"
Vars="*res://scripts/autoloads/Vars.gd"
WordHandler="*res://scripts/autoloads/WordHandler.gd"
Definitions="*res://scripts/autoloads/Definitions.gd"
AdminVars="*res://scripts/autoloads/AdminVars.gd"
DevTools="*res://scripts/utils/dev_tools.gd"
Utils="*res://scripts/autoloads/Utils.gd"
View="*res://scripts/autoloads/View.gd"
VisualSpeech="*res://scripts/utils/visual_speech.gd"
SentenceGenerator="*res://scripts/autoloads/SentenceGenerator.gd"
JsonSerializer="*res://scripts/autoloads/JSONSerializer.gd"
FontManager="*res://scripts/autoloads/FontManager.gd"
IntroHandler="*res://scripts/autoloads/IntroHandler.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=1344
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1
display_server/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/baguettefrenchadmin/plugin.cfg")

[filesystem]

import/blender/enabled=false

[global_group]

ScreenProgressBar=""
MatchTo=""
MatchToSelected=""
FontColorSwitch=""

[input]

click={
