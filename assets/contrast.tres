code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D screen_tex_frg_3 : hint_screen_texture;
uniform float FloatParameter;



void fragment() {
	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(screen_tex_frg_3, SCREEN_UV);


// FloatParameter:5
	float n_out5p0 = FloatParameter;


// VectorCompose:6
	vec3 n_out6p0 = vec3(n_out5p0, n_out5p0, n_out5p0);


// VectorOp:4
	vec3 n_out4p0 = vec3(n_out3p0.xyz) * n_out6p0;


// Input:2
	vec4 n_out2p0 = COLOR;
	float n_out2p4 = n_out2p0.a;


// Output:0
	COLOR.rgb = n_out4p0;
	COLOR.a = n_out2p4;


}
"
