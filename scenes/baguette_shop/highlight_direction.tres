code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 ColorParameter : source_color;
uniform vec4 Direction : source_color;



void fragment() {
// ColorParameter:13
	vec4 n_out13p0 = ColorParameter;


// ColorParameter:17
	vec4 n_out17p0 = Direction;
	float n_out17p1 = n_out17p0.r;


	float n_out26p0;
// Remap:26
	float n_in26p1 = 0.00000;
	float n_in26p2 = 1.00000;
	float n_in26p3 = -1.00000;
	float n_in26p4 = 1.00000;
	{
		float __input_range = n_in26p2 - n_in26p1;
		float __output_range = n_in26p4 - n_in26p3;
		n_out26p0 = n_in26p3 + __output_range * ((n_out17p1 - n_in26p1) / __input_range);
	}


// Clamp:28
	float n_in28p1 = -1.00000;
	float n_in28p2 = 0.00000;
	float n_out28p0 = clamp(n_out26p0, n_in28p1, n_in28p2);


// Compare:36
	float n_in36p1 = 0.00000;
	float n_in36p2 = 0.00001;
	bool n_out36p0 = (abs(n_out28p0 - n_in36p1) < n_in36p2);

// FloatFunc:25
	float n_out25p0 = abs(n_out28p0);


// MultiplyAdd:34
	float n_in34p1 = -2.00000;
	float n_in34p2 = 2.00000;
	float n_out34p0 = fma(n_out25p0, n_in34p1, n_in34p2);


// Input:23
	vec4 n_out23p0 = COLOR;
	float n_out23p1 = n_out23p0.r;


// FloatOp:27
	float n_out27p0 = n_out34p0 - n_out23p1;


// FloatOp:30
	float n_in30p0 = 0.00000;
	float n_out30p0 = n_in30p0 + n_out27p0;


	float n_out35p0;
// Switch:35
	float n_in35p1 = 0.00000;
	n_out35p0 = mix(n_out30p0, n_in35p1, float(n_out36p0));


	float n_out20p0;
// Remap:20
	float n_in20p1 = 0.00000;
	float n_in20p2 = 1.00000;
	float n_in20p3 = -1.00000;
	float n_in20p4 = 1.00000;
	{
		float __input_range = n_in20p2 - n_in20p1;
		float __output_range = n_in20p4 - n_in20p3;
		n_out20p0 = n_in20p3 + __output_range * ((n_out17p1 - n_in20p1) / __input_range);
	}


// FloatOp:31
	float n_in31p1 = 0.00000;
	float n_out31p0 = max(n_out20p0, n_in31p1);


// Compare:33
	float n_in33p1 = 0.00000;
	float n_in33p2 = 0.00001;
	bool n_out33p0 = (abs(n_out31p0 - n_in33p1) < n_in33p2);

// Input:14
	vec4 n_out14p0 = COLOR;
	float n_out14p1 = n_out14p0.r;


// FloatOp:15
	float n_out15p0 = n_out14p1 - n_out31p0;


	float n_out32p0;
// Switch:32
	float n_in32p1 = 0.00000;
	n_out32p0 = mix(n_out15p0, n_in32p1, float(n_out33p0));


// FloatOp:37
	float n_out37p0 = n_out35p0 + n_out32p0;


// FloatOp:18
	float n_in18p1 = 0.50000;
	float n_out18p0 = min(n_out37p0, n_in18p1);


// Input:22
	vec4 n_out22p0 = COLOR;
	float n_out22p4 = n_out22p0.a;


// FloatOp:21
	float n_out21p0 = n_out18p0 * n_out22p4;


// Output:0
	COLOR.rgb = vec3(n_out13p0.xyz);
	COLOR.a = n_out21p0;


}
