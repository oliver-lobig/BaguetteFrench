code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 ShadowColor : source_color;
uniform sampler2D Texture2DParameter : repeat_enable;
uniform vec4 ModulateTexture : source_color;



void fragment() {
// Input:9
	vec4 n_out9p0 = COLOR;


// Compare:10
	float n_in10p1 = 0.00000;
	float n_in10p2 = 0.10000;
	bool n_out10p0 = (abs(n_out9p0.x - n_in10p1) < n_in10p2);

// ColorParameter:12
	vec4 n_out12p0 = ShadowColor;


// Input:4
	vec2 n_out4p0 = UV;


// UVFunc:5
	vec2 n_in5p1 = vec2(2.00000, 2.00000);
	vec2 n_in5p2 = vec2(0.00000, 0.00000);
	vec2 n_out5p0 = (n_out4p0 - n_in5p2) * n_in5p1 + n_in5p2;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(Texture2DParameter, n_out5p0);


// ColorParameter:14
	vec4 n_out14p0 = ModulateTexture;


// VectorOp:13
	vec3 n_out13p0 = vec3(n_out3p0.xyz) * vec3(n_out14p0.xyz);


	vec3 n_out11p0;
// Switch:11
	n_out11p0 = mix(n_out13p0, vec3(n_out12p0.xyz), float(n_out10p0));


// Output:0
	COLOR.rgb = n_out11p0;


}
"
